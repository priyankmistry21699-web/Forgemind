# ============================================================
# ForgeMind — Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
#
# NOTE: When running via Docker Compose, service hostnames
# (postgres, redis) are set automatically in the compose file.
# These defaults are for running services directly on the host.
# ============================================================

# ---- General ----
APP_ENV=development
DEBUG=true
SECRET_KEY=change-me-to-a-random-secret

# ---- Backend (FastAPI) ----
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1
CORS_ORIGINS=http://localhost:3000

# ---- Frontend (Next.js) ----
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# ---- PostgreSQL ----
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=forgemind
POSTGRES_USER=forgemind
POSTGRES_PASSWORD=change-me

# Full connection string (constructed from above or set directly)
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/0

# ---- Celery ----
CELERY_BROKER_URL=redis://${REDIS_HOST}:${REDIS_PORT}/1
CELERY_RESULT_BACKEND=redis://${REDIS_HOST}:${REDIS_PORT}/2

# ---- Auth (Clerk) ----
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_WEBHOOK_SECRET=

# ---- LLM Gateway (LiteLLM) ----
LITELLM_MODEL=gpt-4o
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ---- Ollama (local models) ----
OLLAMA_BASE_URL=http://localhost:11434

# ---- Object Storage (MinIO / S3 / R2) ----
STORAGE_BACKEND=minio
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=forgemind-artifacts
MINIO_USE_SSL=false

# ---- Token Vault Encryption ----
TOKEN_VAULT_KEY=change-me-to-a-fernet-key

# ---- Monitoring (optional) ----
SENTRY_DSN=
PROMETHEUS_ENABLED=false

# ---- ForgeMind Local Agent ----
LOCAL_AGENT_ALLOWED_DIRS=
LOCAL_AGENT_WS_URL=ws://localhost:8000/ws/local-agent
